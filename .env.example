# 맞춤 묵상 / 기도문 생성에 사용하는 Google Gemini API 키.
# https://aistudio.google.com/apikey 에서 발급.
GEMINI_API_KEY=AIza...
# (선택) 모델 지정. 기본값 gemini-2.0-flash. 가장 저렴하게 하려면 gemini-2.0-flash-lite
# GEMINI_MODEL=gemini-2.0-flash

# ── 성경 책장 (api/bible.js) ──
# getBible 공개 API를 쓰므로 API 키는 필요 없습니다.
# (선택) 번역본 변경. 기본값 'korean'(개역성경). 라이선스 받은 본문으로 교체 시 사용.
# BIBLE_TRANSLATION=korean
# (선택) 본문 캐시 시간(초). 기본값 86400(하루).
# BIBLE_CACHE_SECONDS=86400
